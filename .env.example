# Copiá este archivo a .env y ajustá los valores

# Clave secreta para firmar los JWT. En producción usá una clave larga y aleatoria.
# Generala con: openssl rand -hex 32
SECRET_KEY=changeme-genera-una-clave-aleatoria-y-larga

# Algoritmo de firma del JWT
ALGORITHM=HS256

# Minutos de validez del access token
ACCESS_TOKEN_EXPIRE_MINUTES=60

# URL de la base de datos (SQLite para desarrollo local)
DATABASE_URL=sqlite:///./tienda.db

# Orígenes permitidos por CORS, separados por coma
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Entorno: development | production
ENVIRONMENT=development
